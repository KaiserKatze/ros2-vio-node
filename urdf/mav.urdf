<?xml version="1.0"?>
<robot name="euroc_mav" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <cylinder length="0.1" radius="1" />
      </geometry>
    </visual>
    <material name="blue">
      <color rgba="0 0 1 0.9" />
    </material>
  </link>

  <link name="tail_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="1 0.1 0.1" />
      </geometry>
      <material name="red">
        <color rgba="1 0 0 0.9" />
      </material>
    </visual>
  </link>

  <joint name="base_tail_joint" type="fixed">
    <origin xyz="0 0 0.05" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="tail_link" />
  </joint>

</robot>
